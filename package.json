{
  "name": "sprintster",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "dev": "pnpm -r --parallel run dev",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo node_modules/.cache",
    "install-s8r": "pnpm -r run build && node scripts/install-s8r.mjs",
    "remove-s8r": "node scripts/remove-s8r.mjs",
    "test:e2e": "pnpm -r run build && bash tests/e2e/smoke.sh",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
